<?xml version="1.0"?>
<!DOCTYPE fontconfig SYSTEM "fonts.dtd">
<fontconfig>
    <!-- Aliases for commonly used MS fonts. -->
    <alias>
        <family>Arial</family>
        <prefer><family>sans-serif</family></prefer>
    </alias>
    <alias>
        <family>Tahoma</family>
        <prefer><family>sans-serif</family></prefer>
    </alias>
    <alias>
        <family>Verdana</family>
        <prefer><family>sans-serif</family></prefer>
    </alias>
    <alias>
        <family>Helvetica</family>
        <prefer><family>sans-serif</family></prefer>
    </alias>
    <alias>
        <family>Times</family>
        <prefer><family>serif</family></prefer>
    </alias>
    <alias>
        <family>Times New Roman</family>
        <prefer><family>serif</family></prefer>
    </alias>
    <alias>
        <family>Courier</family>
        <prefer><family>monospace</family></prefer>
    </alias>
    <alias>
        <family>Courier New</family>
        <prefer><family>monospace</family></prefer>
    </alias>
    <alias>
        <family>Consolas</family>
        <prefer><family>monospace</family></prefer>
    </alias>
    <alias>
        <family>Calibri</family>
        <prefer><family>sans-serif</family></prefer>
    </alias>
    <alias>
        <family>Cambria</family>
        <prefer><family>sans-serif</family></prefer>
    </alias>

    <!-- Aliases for serif, sans-serif and monospace. -->
    <alias>
        <family>serif</family>
        <prefer><family>{{ serif_font }}</family></prefer>
    </alias>
    <alias>
        <family>sans</family>
        <prefer><family>{{ sans_font }}</family></prefer>
    </alias>
    <alias>
        <family>sans-serif</family>
        <prefer><family>{{ sans_font }}</family></prefer>
    </alias>
    <alias>
        <family>monospace</family>
        <prefer><family>{{ monospace_font }}</family></prefer>
    </alias>
</fontconfig>
