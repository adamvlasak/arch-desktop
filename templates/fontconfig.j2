<?xml version="1.0"?>
<!DOCTYPE fontconfig SYSTEM "fonts.dtd">
<fontconfig>
    <!-- default fonts -->
    <alias>
        <family>serif</family>
        <prefer>
            <family>{{ serif_font }}</family>
        </prefer>
    </alias>
    <alias>
        <family>{{ serif_font }}</family>
        <default>
            <family>serif</family>
        </default>
    </alias>
    <alias>
        <family>sans-serif</family>
        <prefer>
            <family>{{ sans_font }}</family>
        </prefer>
    </alias>
    <alias>
        <family>{{ sans_font }}</family>
        <default>
            <family>sans-serif</family>
        </default>
    </alias>
    <alias>
        <family>monospace</family>
        <prefer>
            <family>{{ monospace_font }}</family>
        </prefer>
    </alias>
    <alias>
        <family>{{ monospace_font }}</family>
        <default>
            <family>monospace</family>
        </default>
    </alias>
    <!-- /default fonts -->

    <!-- replacements -->
    <match target="pattern">
        <test qual="any" name="family"><string>Cantarell</string></test>
        <edit name="family" mode="assign" binding="same"><string>{{ sans_font }}</string></edit>
    </match>
    <!-- /replacements -->

    <!-- rendering settings -->
    <match target="font">
        <edit name="antialias" mode="assign">
            <bool>{{ antialias }}</bool>
        </edit>
    </match>
    <match target="font">
        <edit name="autohint" mode="assign">
            <bool>{{ autohint }}</bool>
        </edit>
    </match>
    <match target="font">
        <edit name="hinting" mode="assign">
            <bool>{{ hinting }}</bool>
        </edit>
    </match>
    <match target="font">
        <edit name="hintstyle" mode="assign">
            <const>{{ hintstyle }}</const>
        </edit>
    </match>
    <match target="font">
        <edit name="lcdfilter" mode="assign">
            <const>{{ lcdfilter }}</const>
        </edit>
    </match>
    <match target="font">
        <edit name="rgba" mode="assign">
            <const>{{ rgba }}</const>
        </edit>
    </match>
    <match target="pattern">
        <edit name="dpi" mode="assign"><double>{{ dpi }}</double></edit>
    </match>
    <!-- /rendering settings -->
</fontconfig>
