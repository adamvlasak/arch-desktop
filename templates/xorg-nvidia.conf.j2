Section "Device"
  Identifier "Device0"
  Driver "nvidia"
  VendorName "NVIDIA Corporation"
  BoardName "GeForce GTX 970"
EndSection

Section "Monitor"
    Identifier "Monitor0"
EndSection

Section "Screen"
    Identifier     "Screen0"
    Device         "Device0"
    Monitor        "Monitor0"
    Option         "TripleBuffer" "on"
    Option         "AllowIndirectGLXProtocol" "off"
    Option         "SLI" "Off"
    Option         "PrimaryGPU" "true"
    Option         "MultiGPU" "Off"
    Option         "BaseMosaic" "off"
    DefaultDepth   24
    SubSection     "Display"
        Depth      24
    EndSubSection
EndSection
